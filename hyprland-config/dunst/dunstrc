# Dunst Configuration - Modern Notification Daemon
# Matches the Cyber Synthwave theme

[global]
    # Display
    monitor = 0
    follow = mouse
    
    # Geometry
    width = (300, 400)
    height = (0, 300)
    origin = top-right
    offset = 12x48
    scale = 0
    notification_limit = 5
    
    # Progress bar
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 5
    
    # Style
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 3
    frame_color = "#ee1111"
    gap_size = 6
    separator_color = frame
    sort = true
    
    # Text
    font = JetBrainsMono Nerd Font 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = true
    
    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    
    # History
    sticky_history = true
    history_length = 20
    
    # Misc
    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 12
    ignore_dbusclose = false
    
    # Mouse
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1a1a1add"
    foreground = "#e0e0e0"
    frame_color = "#2a3341"
    timeout = 5
[urgency_normal]
    background = "#1a1a1aee"
    foreground = "#e0e0e0"
    frame_color = "#ee1111"
    timeout = 8
[urgency_critical]
    background = "#1a1a1af0"
    foreground = "#ff0055"
    frame_color = "#ff0055"
    timeout = 0
# App-specific rules
[discord]
    appname = "discord"
    urgency = low
    frame_color = "#cc0000"
    
[spotify]
    appname = "Spotify"
    urgency = low
    frame_color = "#00ff9f"
